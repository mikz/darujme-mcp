# Live Darujme API credentials for local development and e2e tests.
# Read-only e2e tests skip when any required value is missing.
DARUJME_API_ID=
DARUJME_API_SECRET=
# Required: Darujme API v1 does not provide token introspection or organization discovery.
DARUJME_ORGANIZATION_ID=

# Optional overrides.
# DARUJME_BASE_URL=https://www.darujme.cz/api/v1/
# DARUJME_TIMEOUT_SECONDS=30
